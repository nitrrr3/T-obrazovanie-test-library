class Book:
    def __init__(self, title:str, author:str, genre:str, year_of_publication:int, description:str,favorites, read, Library):
        self.title = title.replace(';', ',')
        self.author = author.replace(';', ',')
        self.genre = genre.replace(';', ',')
        self.year_of_publication = year_of_publication
        self.description = description.replace(';', ',')
        self.favorites = favorites
        self.read = read
        self.Library = Library
        self.Library.append(self)
        self.dict_parameters = {"название": self.title, "автор": self.author, "жанр": self.genre,
                          "год публикации": self.year_of_publication, "описание": self.description,
                          "избранное": self.favorites, "прочитано": self.read}
    def book_view(self):
        return (f"""{'"'}{self.title}{'"'} автор: {self.author}, жанр: {self.genre}, год публикации: {self.year_of_publication}
В избранном: {"да" if True == self.favorites else "нет"}, прочитана: {"да" if True == self.read else "нет"}. Описание:
{self.description}""")

    def change_str_book(self, parameter, new_parameter, id):
        self.dict_parameters[parameter] = new_parameter
        print("Параметр успешно изменён.")
        update_book(id, self)

    def change_bool_book(self, parameter, new_parameter, id):
        self.dict_parameters[parameter] = True if 1 in new_parameter else False
        print("Параметр успешно изменён.")
        update_book(id, self)

    def change_int_book(self, parameter, new_parameter, id):
        self.dict_parameters[parameter] = int(new_parameter)
        print("Параметр успешно изменён.")
        update_book(id, self)
