import sqlite3
connection = sqlite3.connect('lib.db')
cursor = connection.cursor()
cursor.execute('''
CREATE TABLE IF NOT EXISTS Books (
id INTEGER PRIMARY KEY,
title TEXT,
author TEXT,
genre TEXT,
year_of_publication INTEGER,
description TEXT,
favorites BULL,
read BULL
)
''')
connection.commit()
connection.close()

def write_book(book):
    connection = sqlite3.connect('lib.db')
    cursor = connection.cursor()
    cursor.execute('INSERT INTO Books (title,author,genre,year_of_publication,description,favorites,read) VALUES (?, ?, ?, ?, ?, ?, ?)', (book.title, book.author, book.genre, book.year_of_publication, book.description, book.favorites, book.read))
    connection.commit()
    connection.close()
def update_book(id,book):
    connection = sqlite3.connect('lib.db')
    cursor = connection.cursor()
    cursor.execute('UPDATE Books SET title = ?,author = ?,genre = ?,year_of_publication = ?,description = ?,favorites = ?,read = ? id = ?', (book.title, book.author, book.genre, book.year_of_publication, book.description, book.favorites, book.read,id))
    connection.commit()
    connection.close()
def delete_book(id):
    connection = sqlite3.connect('lib.db')
    cursor = connection.cursor()
    cursor.execute('DELETE FROM Books WHERE id = ?',(id,))
    connection.commit()
    connection.close()
